{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": [
      "smallreterminator",
      "reterminator",
      "openrouter"
    ],
    "instructions": [
      "{env:HOME}/.config/opencode/karpathy-maxims.md",
    ],
    "default_agent": "plan",
    "plugin": ["opencode-smart-voice-notify@latest"],
    "share": "disabled",
    "model": "reterminator/qw3.6-35b-multimodalcoding-Q6_K-default-ctx128k",
    "small_model": "smallreterminator/qw3.5-2b-nonthinking-Q5_K_S-default-ctx16k",
    "provider": {
        "reterminator": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "reterminator",
            "options": {
                "baseURL": "http://localhost:9292/v1/",
            },
            "models": {
                "qw3.6-35b-multimodalcoding-Q6_K-default-ctx128k": {
                  "name": "Qwen3.6 multimodalcoding Q6_K 128k",
                  "modalities": {
                    "input": ["text", "image"],
                    "output": ["text"]
                  },
                },
                "qw3.6-35b-multimodalcoding-IQ3_XXS-default-ctx128k": {
                  "name": "Qwen3.6 multimodalcoding IQ3_XSS 128k",
                  "modalities": {
                    "input": ["text", "image"],
                    "output": ["text"]
                  },
                },
                "gemma4-26b-default-Q4_K_M-midperf-ctx128k": {
                  "name": "Gemma4 26B Q4_K_M midperf 128k",
                },
                "gemma4-26b-default-Q6_K-default-ctx192k": {
                  "name": "Gemma4 26B Q6_K default 192k"
                },
            }
        },
        "smallreterminator": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "reterminator",
            "options": {
                "baseURL": "http://localhost:9292/small/v1/",
            },
            "models": {
                "qw3.5-4b-thinking-Q5_K_S-default-ctx256k":              { "name": "Qwen3.5 thinking 4B Q5_K_S 256" },
                "qw3.5-4b-nonthinking-Q5_K_S-default-ctx256k":           { "name": "Qwen3.5 nonthinking 4B Q5_K_S 256" },
            }
        },
    },
    "mcp": {
        "webmcp": {
          "type": "remote",
          "url": "http://192.168.0.16:3952/sse",
          "enabled": true,
        },
        "ytsummarisermcp": {
          "type": "remote",
          "url": "http://192.168.0.16:9042/mcp",
          "enabled": true,
        },
        "wayland-screenshot": {
          "type": "local",
          "command": ["{env:HOME}/repos/s-mcp-screenuse/scripts/s-mcp-screenuse.sh"],
          "enabled": true
        },
    },
}
