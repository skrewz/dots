{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": [
      "smallreterminator",
      "reterminator",
      "openrouter"
    ],
    "default_agent": "plan",
    "plugin": ["opencode-smart-voice-notify@latest"],
    "share": "disabled",
    "small_model": "smallreterminator/qw3.5-2b-nonthinking-Q5_K_S-default-ctx16k",
    "provider": {
        "reterminator": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "reterminator",
            "options": {
                "baseURL": "http://localhost:9292/v1/",
            },
            "models": {
                "qw3.5-35b-coding-UD-Q6_K_S-lowperf-ctx192k":            { "name": "Qwen3.5 coding preset UD-Q6_K_S lowperf 192k" },
                "qw3.5-35b-thinking-UD-Q6_K_S-lowperf-ctx192k":          { "name": "Qwen3.5 thinking UD-Q6_K_S lowperf 192k" },
                "qw3.5-35b-nonthinking-MXFP4_MOE-lowperf-ctx256k":       { "name": "Qwen3.5 non-thinking MXFP4_MOE lowperf 256k" },
                "qw3.5-35b-thinking-MXFP4_MOE-lowperf-ctx256k":          { "name": "Qwen3.5 thinking MXFP4_MOE lowperf 256k" },
                "gemma4-26b-default-Q4_K_M-midperf-ctx128k":             { "name": "Gemma4 26B Q4_K_M midperf 128k" },
                "gemma4-26b-default-Q6_K-lowperf-ctx192k":               { "name": "Gemma4 26B Q6_K lowperf 192k" },
                "darwin-35b-coding-Q6_K-default-ctx128k":                { "name": "Darwin 35B-A3B Opus distil 128k" },
            }
        },
        "smallreterminator": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "reterminator",
            "options": {
                "baseURL": "http://localhost:9292/small/v1/",
            },
            "models": {
                "qw3.5-4b-thinking-Q5_K_S-default-ctx256k":              { "name": "Qwen3.5 thinking 4B Q5_K_S 256" },
                "qw3.5-4b-nonthinking-Q5_K_S-default-ctx256k":           { "name": "Qwen3.5 nonthinking 4B Q5_K_S 256" },
            }
        },
    },
    "mcp": {
        "webmcp": {
          "type": "remote",
          "url": "http://192.168.0.16:3952/sse",
          "enabled": true,
        },
        "ytsummarisermcp": {
          "type": "remote",
          "url": "http://192.168.0.16:9042/mcp",
          "enabled": true,
        },
    },
}
